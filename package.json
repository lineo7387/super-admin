{
  "name": "super-admin",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter @super-admin/admin dev",
    "build": "pnpm -r build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test && vitest run scripts/*.test.mjs",
    "validate:starter": "node scripts/validate-starter-smoke.mjs",
    "test:reference": "vitest run scripts/reference-integration-smoke.test.mjs && node scripts/reference-integration-smoke.mjs",
    "lint": "pnpm lint:types && pnpm lint:eslint && pnpm lint:prettier-conflicts",
    "lint:types": "pnpm -r typecheck",
    "lint:eslint": "eslint . --max-warnings=0",
    "lint:prettier-conflicts": "eslint-config-prettier apps/admin/src/App.vue apps/admin/src/main.ts packages/core/src/index.ts scripts/release.mjs",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "validate:publish": "node scripts/publish-readiness.mjs",
    "changeset": "changeset",
    "release": "node scripts/release.mjs",
    "release:check": "node scripts/release.mjs check",
    "release:version": "node scripts/release.mjs version",
    "release:bootstrap:prepare": "node scripts/release.mjs bootstrap:prepare",
    "release:commands": "node scripts/release.mjs commands"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.3",
    "@types/node": "^24.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "playwright": "^1.61.0",
    "prettier": "^3.9.4",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.0.16",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.9",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.0.0"
  },
  "pnpm": {
    "overrides": {
      "tsx>esbuild": "0.28.1"
    }
  }
}
