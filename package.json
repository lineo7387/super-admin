{
  "name": "super-admin",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter @super-admin/admin dev",
    "build": "pnpm -r build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test && vitest run scripts/*.test.mjs",
    "validate:starter": "node scripts/validate-generated-starter.mjs",
    "test:reference": "vitest run scripts/reference-integration-smoke.test.mjs && node scripts/reference-integration-smoke.mjs",
    "lint": "pnpm -r lint",
    "validate:publish": "node scripts/publish-readiness.mjs",
    "changeset": "changeset",
    "release": "node scripts/release.mjs",
    "release:check": "node scripts/release.mjs check",
    "release:version": "node scripts/release.mjs version",
    "release:bootstrap:prepare": "node scripts/release.mjs bootstrap:prepare",
    "release:commands": "node scripts/release.mjs commands"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^24.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "playwright": "^1.60.0",
    "typescript": "^5.0.0",
    "vite": "^7.0.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.0",
    "vue-tsc": "^3.0.0"
  }
}
