{
  "name": "create-super-admin",
  "version": "0.2.0",
  "type": "module",
  "bin": {
    "create-super-admin": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "prepublishOnly": "node ../../scripts/prepublish-guard.mjs .",
    "build": "node ../../scripts/write-cli-package-version-ranges.mjs && tsc -p tsconfig.build.json && node ../../scripts/build-cli-template.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.9"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lineo7387/super-admin.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/lineo7387/super-admin/issues"
  },
  "homepage": "https://github.com/lineo7387/super-admin#readme",
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts"
}
